# Required
DISCORD_TOKEN=your_discord_bot_token
GUILD_ID=your_discord_server_id
MANAGED_GUILD_IDS=

# Optional core settings
# These channel IDs act as global defaults. Per-guild values in /admin/guild-settings override them.
BOT_LOG_CHANNEL_ID=0
# Legacy alias (supported for backward compatibility)
# GENERAL_CHANNEL_ID=0
DATA_DIR=data
LOG_DIR=/logs
LOG_HARDEN_FILE_PERMISSIONS=true
LOG_RETENTION_DAYS=90
LOG_ROTATION_INTERVAL_DAYS=1
LOG_LEVEL=INFO
CONTAINER_LOG_LEVEL=ERROR
DISCORD_LOG_LEVEL=INFO

# Search settings
FORUM_BASE_URL=https://forum.gl-inet.com
FORUM_MAX_RESULTS=5
REDDIT_SUBREDDIT=GlInet
REDDIT_FEED_CHECK_SCHEDULE=*/30 * * * *
DOCS_MAX_RESULTS_PER_SITE=2
DOCS_INDEX_TTL_SECONDS=3600
SEARCH_RESPONSE_MAX_CHARS=1900
BOT_HELP_WIKI_URL=https://github.com/wickedyoda/Glinet_discord_bot/wiki/Home

# Utility and integration settings
# These feature toggles act as global defaults. Per-guild overrides in /admin/guild-settings can enable or disable them for individual servers.
ENABLE_MEMBERS_INTENT=true
MEMBER_ACTIVITY_BACKFILL_ENABLED=false
MEMBER_ACTIVITY_BACKFILL_GUILD_ID=
MEMBER_ACTIVITY_BACKFILL_SINCE=
# Optional. If blank, the bot creates and persists a local key at ${DATA_DIR}/member_activity.key
MEMBER_ACTIVITY_ENCRYPTION_KEY=
COMMAND_RESPONSES_EPHEMERAL=false
PUPPY_IMAGE_API_URL=https://dog.ceo/api/breeds/image/random
PUPPY_IMAGE_TIMEOUT_SECONDS=8
SHORTENER_ENABLED=false
SHORTENER_BASE_URL=https://short.example.com
SHORTENER_TIMEOUT_SECONDS=10
FIRMWARE_MONITOR_ENABLED=true
REDDIT_FEED_NOTIFY_ENABLED=true
YOUTUBE_NOTIFY_ENABLED=false
YOUTUBE_POLL_INTERVAL_SECONDS=300
YOUTUBE_REQUEST_TIMEOUT_SECONDS=12
LINKEDIN_NOTIFY_ENABLED=true
LINKEDIN_POLL_INTERVAL_SECONDS=900
LINKEDIN_REQUEST_TIMEOUT_SECONDS=15
BETA_PROGRAM_PAGE_URL=https://www.gl-inet.com/beta-testing/#register
BETA_PROGRAM_NOTIFY_ENABLED=true
BETA_PROGRAM_POLL_INTERVAL_SECONDS=900
BETA_PROGRAM_REQUEST_TIMEOUT_SECONDS=20
SERVICE_MONITOR_ENABLED=false
SERVICE_MONITOR_DEFAULT_CHANNEL_ID=
SERVICE_MONITOR_CHECK_SCHEDULE=*/5 * * * *
SERVICE_MONITOR_REQUEST_TIMEOUT_SECONDS=10
SERVICE_MONITOR_TARGETS_JSON=[]
UPTIME_STATUS_ENABLED=false
UPTIME_STATUS_NOTIFY_ENABLED=false
UPTIME_STATUS_NOTIFY_CHANNEL_ID=
UPTIME_STATUS_CHECK_SCHEDULE=*/5 * * * *
UPTIME_STATUS_PAGE_URL=https://status.example.com/status/everything
UPTIME_STATUS_INSTANCE_URL=
UPTIME_STATUS_API_KEY=
UPTIME_STATUS_TIMEOUT_SECONDS=10
UPTIME_STATUS_VERIFY_TLS=true

# Moderation settings
# MOD_LOG_CHANNEL_ID acts as a global default. Per-guild values in /admin/guild-settings override it.
KICK_PRUNE_HOURS=72
MODERATOR_ROLE_ID=1294957416294645771
ADMIN_ROLE_ID=1138302148292116551
MOD_LOG_CHANNEL_ID=1311820410269995009

# CSV role assignment settings
CSV_ROLE_ASSIGN_MAX_NAMES=500

# Firmware monitor settings
# firmware_notification_channel acts as a global default. Per-guild values in /admin/guild-settings override it.
firmware_notification_channel=123456789012345678
# Optional uppercase alias (recommended for some Portainer stacks)
# FIRMWARE_NOTIFICATION_CHANNEL=123456789012345678
# Optional legacy alias (supported for backward compatibility)
# FIRMWARE_NOTIFY_CHANNEL_ID=123456789012345678
FIRMWARE_FEED_URL=https://gl-fw.remotetohome.io/
firmware_check_schedule=*/30 * * * *
# Optional uppercase alias (recommended for some Portainer stacks)
# FIRMWARE_CHECK_SCHEDULE=*/30 * * * *
# Optional legacy fallback (used only when firmware_check_schedule is empty)
# FIRMWARE_CHECK_INTERVAL_SECONDS=1800
FIRMWARE_REQUEST_TIMEOUT_SECONDS=30
FIRMWARE_RELEASE_NOTES_MAX_CHARS=900

# Web admin settings
WEB_ENABLED=true
WEB_BIND_HOST=0.0.0.0
WEB_PORT=8080
# Optional explicit HTTP publish override for Docker/Compose.
# Leave commented to disable host/IP pinning and publish on all host interfaces.
# Examples:
# WEB_HTTP_PUBLISH=8080
# WEB_HTTP_PUBLISH=127.0.0.1:8080
# WEB_HTTP_PUBLISH=192.168.1.50:8080
WEB_HTTPS_ENABLED=true
WEB_HTTPS_PORT=8081
# Optional explicit HTTPS publish override for Docker/Compose.
# Leave commented to disable host/IP pinning and publish on all host interfaces.
# Examples:
# WEB_HTTPS_PUBLISH=8081
# WEB_HTTPS_PUBLISH=127.0.0.1:8081
# WEB_HTTPS_PUBLISH=192.168.1.50:8081
WEB_SESSION_TIMEOUT_MINUTES=60
WEB_PUBLIC_BASE_URL=https://discord-admin.example.com/
WEB_SSL_DIR=data/ssl
WEB_SSL_CERT_FILE=tls.crt
WEB_SSL_KEY_FILE=tls.key
WEB_SSL_COMMON_NAME=localhost
WEB_ENV_FILE=data/web-settings.env
WEB_RESTART_ENABLED=true
WEB_GITHUB_WIKI_URL=https://github.com/wickedyoda/Glinet_discord_bot/wiki
WEB_ADMIN_DEFAULT_USERNAME=admin@example.com
# Optional alias (if set, used before WEB_ADMIN_DEFAULT_USERNAME)
# WEB_ADMIN_DEFAULT_EMAIL=admin@example.com
# Password policy: 6-16 chars, at least 2 numbers, 1 uppercase letter, 1 symbol
WEB_ADMIN_DEFAULT_PASSWORD=Ab!12xy
WEB_ADMIN_SESSION_SECRET=replace_with_random_secret
WEB_SESSION_COOKIE_SECURE=true
WEB_SESSION_COOKIE_SAMESITE=Lax
WEB_TRUST_PROXY_HEADERS=true
WEB_ENFORCE_CSRF=true
WEB_ENFORCE_SAME_ORIGIN_POSTS=true
WEB_HARDEN_FILE_PERMISSIONS=true

# Web Discord catalog + CSV upload tuning
WEB_DISCORD_CATALOG_TTL_SECONDS=120
WEB_DISCORD_CATALOG_FETCH_TIMEOUT_SECONDS=20
WEB_BULK_ASSIGN_TIMEOUT_SECONDS=300
WEB_BULK_ASSIGN_MAX_UPLOAD_BYTES=2097152
WEB_BULK_ASSIGN_REPORT_LIST_LIMIT=50
WEB_BOT_PROFILE_TIMEOUT_SECONDS=20
# Shared upload cap for bot-profile avatars and guild welcome images
WEB_AVATAR_MAX_UPLOAD_BYTES=2097152
